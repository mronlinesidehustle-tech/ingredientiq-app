{
    "buildCommand": "",
    "outputDirectory": "public",
    "framework": null,
    "rewrites": [
          { "source": "/(.*)", "destination": "/index.html" }
    ],
    "headers": [
          {
                  "source": "/recipes_data.json",
                  "headers": [
                            { "key": "Cache-Control", "value": "public, max-age=86400" },
                            { "key": "Content-Type", "value": "application/json" }
                  ]
          }
    ]
}
